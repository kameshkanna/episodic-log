# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# --- Groq API (required for haiku/self summarizer and evaluate.py) ---
GROQ_API_KEY=your_groq_api_key_here

# --- HuggingFace (required for local HF models) ---
HF_TOKEN=your_hf_token_here

# --- Optional: override default data directory ---
# EPISODIC_DATA_DIR=data

# --- Optional: default provider spec for evaluate.py ---
# EPISODIC_PROVIDER=groq:llama-3.1-8b-instant
# EPISODIC_JUDGE_PROVIDER=groq:llama-3.1-70b-versatile
